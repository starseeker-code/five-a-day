# ============================================================================
# DOCKERIGNORE - Archivos a excluir de la imagen Docker
# ============================================================================
# Esto optimiza el tamaño de la imagen y acelera el build

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual Environments
venv/
env/
ENV/
.venv

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# Docker
Dockerfile
docker-compose*.yml
.dockerignore

# Documentation
README.md
docs/
*.md

# Tests
tests/
.pytest_cache/
.coverage
htmlcov/

# Environment variables
.env
.env.*
!.env.example

# Database
*.sqlite3
*.db

# Media and Static (se recolectan en runtime)
staticfiles/
mediafiles/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Scripts de desarrollo
scripts/

# Backups
backups/
